@page "/admin/designations"
@attribute [Authorize(Policy = "perm:" + Permissions.Administration.Settings)]
@inject DesignationsClient Designations
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>EMS — Designations</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
    <MudText Typo="Typo.h5">Designations</MudText>
    <MudSpacer />
    <MudButton StartIcon="@Icons.Material.Filled.Add" Color="Color.Primary"
               Variant="Variant.Filled" OnClick="() => OpenEditor(null)">New designation</MudButton>
</MudStack>

<MudTable T="DesignationDto" Items="_items" Dense="true" Hover="true" Elevation="1" Loading="_loading">
    <HeaderContent>
        <MudTh>Title</MudTh>
        <MudTh>Description</MudTh>
        <MudTh>Employees</MudTh>
        <MudTh Style="width: 100px;"></MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Title">@context.Title</MudTd>
        <MudTd DataLabel="Description">@context.Description</MudTd>
        <MudTd DataLabel="Employees">@context.EmployeeCount</MudTd>
        <MudTd>
            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                           OnClick="() => OpenEditor(context)" aria-label="Edit" />
            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                           OnClick="() => DeleteAsync(context)" aria-label="Delete" />
        </MudTd>
    </RowTemplate>
</MudTable>

<MudDialog @bind-Visible="_editorOpen" Options="_dialogOptions">
    <TitleContent>
        <MudText Typo="Typo.h6">@(_editingId is null ? "New designation" : "Edit designation")</MudText>
    </TitleContent>
    <DialogContent>
        @if (_error is not null)
        {
            <MudAlert Severity="Severity.Error" Dense="true" Class="mb-4">@_error.FullMessage</MudAlert>
        }
        <MudTextField T="string" @bind-Value="_title" Label="Title" Variant="Variant.Outlined"
                      Required="true" Class="mb-3" />
        <MudTextField T="string" @bind-Value="_description" Label="Description"
                      Variant="Variant.Outlined" Lines="2" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => _editorOpen = false">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SaveAsync" Disabled="_saving">Save</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private readonly DialogOptions _dialogOptions = new() { MaxWidth = MaxWidth.Small, FullWidth = true };
    private List<DesignationDto> _items = [];
    private bool _loading = true;
    private bool _editorOpen;
    private bool _saving;
    private int? _editingId;
    private string _title = string.Empty;
    private string? _description;
    private ApiError? _error;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        _items = await Designations.GetAllAsync() ?? [];
        _loading = false;
    }

    private void OpenEditor(DesignationDto? item)
    {
        _editingId = item?.Id;
        _title = item?.Title ?? string.Empty;
        _description = item?.Description;
        _error = null;
        _editorOpen = true;
    }

    private async Task SaveAsync()
    {
        _saving = true;
        _error = null;

        var request = new SaveDesignationRequest(_title, _description);
        _error = _editingId is { } id
            ? await Designations.UpdateAsync(id, request)
            : await Designations.CreateAsync(request);

        _saving = false;

        if (_error is null)
        {
            _editorOpen = false;
            Snackbar.Add(_editingId is null ? "Designation created." : "Designation updated.", Severity.Success);
            await LoadAsync();
        }
    }

    private async Task DeleteAsync(DesignationDto item)
    {
        var confirmed = await DialogService.ShowMessageBoxAsync(
            "Delete designation", $"Delete {item.Title}?",
            yesText: "Delete", cancelText: "Cancel");

        if (confirmed == true)
        {
            var error = await Designations.DeleteAsync(item.Id);
            if (error is null)
            {
                Snackbar.Add("Designation deleted.", Severity.Success);
                await LoadAsync();
            }
            else
            {
                Snackbar.Add(error.FullMessage, Severity.Error);
            }
        }
    }
}
