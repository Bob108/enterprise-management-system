<MudNavMenu>
    <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Dashboard">Dashboard</MudNavLink>
    <MudNavGroup Title="Modules" Icon="@Icons.Material.Filled.Apps" Expanded="true">
        <AuthorizeView Policy="@("perm:" + Permissions.Employees.View)">
            <MudNavLink Href="/employees" Icon="@Icons.Material.Filled.People">Employees</MudNavLink>
        </AuthorizeView>
        <AuthorizeView Policy="@("perm:" + Permissions.Assets.View)">
            <MudNavLink Href="/assets" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Devices">Assets</MudNavLink>
        </AuthorizeView>
        <AuthorizeView Policy="@("perm:" + Permissions.Inventory.View)">
            <MudNavLink Href="/inventory" Icon="@Icons.Material.Filled.Inventory">Inventory</MudNavLink>
        </AuthorizeView>
        <MudNavLink Icon="@Icons.Material.Filled.LocalShipping" Disabled="true">Fleet</MudNavLink>
        <MudNavLink Icon="@Icons.Material.Filled.ShoppingCart" Disabled="true">Procurement</MudNavLink>
        <MudNavLink Icon="@Icons.Material.Filled.Build" Disabled="true">Maintenance</MudNavLink>
        <MudNavLink Icon="@Icons.Material.Filled.EventAvailable" Disabled="true">Leave</MudNavLink>
        <MudNavLink Icon="@Icons.Material.Filled.Assessment" Disabled="true">Reports</MudNavLink>
    </MudNavGroup>
    <AuthorizeView Policy="@("perm:" + Permissions.Administration.Settings)">
        <MudNavGroup Title="Administration" Icon="@Icons.Material.Filled.Settings" Expanded="false">
            <MudNavLink Href="/admin/departments" Icon="@Icons.Material.Filled.AccountTree">Departments</MudNavLink>
            <MudNavLink Href="/admin/designations" Icon="@Icons.Material.Filled.Badge">Designations</MudNavLink>
            <MudNavLink Href="/admin/asset-categories" Icon="@Icons.Material.Filled.Category">Asset categories</MudNavLink>
            <MudNavLink Href="/admin/suppliers" Icon="@Icons.Material.Filled.Storefront">Suppliers</MudNavLink>
            <MudNavLink Href="/admin/warehouses" Icon="@Icons.Material.Filled.Warehouse">Warehouses</MudNavLink>
        </MudNavGroup>
    </AuthorizeView>
</MudNavMenu>
